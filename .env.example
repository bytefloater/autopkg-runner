# AutoPkg Runner — environment template
# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.
#
# IMPORTANT: DJANGO_SECRET_KEY is also the master key for credential
# encryption in the database. If you change it, any encrypted passwords
# (repository.password, notifier tokens) stored in the DB will become
# unreadable and must be re-entered.
#
# Generate a new key:
#   python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_SECRET_KEY=replace-me-with-a-generated-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1
