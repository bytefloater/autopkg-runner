[run]
branch = False
source =
    webapp
    api
    libs
    stages
    notifiers

[report]
omit =
    # macOS launchd/osascript integration — requires a live daemon environment
    webapp/management/commands/service_daemon.py
    webapp/management/commands/purge.py
    # Frozen-bundle entry point — only runs inside a PyInstaller .app
    run.py
    libs/bundled_config.py
    # Django boilerplate
    autopkgrunner/asgi.py
    manage.py
    */migrations/*
